{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write"
  ],
  "required_executas": [
    {
      "tool_id": "note-summarizer"
    }
  ],
  "tags": [
    "notes"
  ],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,
        "default_size": { "w": 480, "h": 600 },
        "min_size": { "w": 320, "h": 400 }
      }
    ],
    "host_api": {
      "tools": [
        "note-summarizer"
      ],
      "storage": [
        "get",
        "set"
      ],
      "window": [
        "set_title",
        "ready"
      ]
    },
    "csp_overrides": {},
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "executas": {
      "note-summarizer": {
        "command": "go run ./tool/main.go",
        "env": {}
      }
    }
  }
}